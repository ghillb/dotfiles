#!/usr/bin/env bash
set -euo pipefail

auth_profiles_dir="${HOME}/.codex-auth-profiles"
current_file="${auth_profiles_dir}/.current"
shared_home="${HOME}/.codex"
shared_auth="${shared_home}/auth.json"

usage() {
  cat <<'EOF'
Usage:
  cx-switch use <name>
  cx-switch current
  cx-switch list
  cx-switch status
  cx-switch limits [name]
EOF
}

validate_profile_name() {
  local name="$1"
  case "$name" in
    *[!A-Za-z0-9._-]*)
      echo "cx-switch: invalid profile name: $name" >&2
      exit 1
      ;;
  esac
}

get_current_profile() {
  if [ -f "$current_file" ]; then
    tr -d '[:space:]' < "$current_file"
    printf '\n'
  else
    echo "unset"
  fi
}

format_reset_at() {
  local epoch="$1"
  local reset_day today
  if [ -z "$epoch" ]; then
    echo "unknown"
    return
  fi

  reset_day="$(date -d "@$epoch" +%F)"
  today="$(date +%F)"
  if [ "$reset_day" = "$today" ]; then
    date -d "@$epoch" +%H:%M
  else
    date -d "@$epoch" +"%H:%M on %-d %b"
  fi
}

window_label() {
  local minutes="$1"
  local fallback="$2"
  case "$minutes" in
    300) echo "5h limit" ;;
    10080) echo "Weekly limit" ;;
    "") echo "$fallback" ;;
    *) echo "${minutes}m limit" ;;
  esac
}

fetch_limits_json() {
  local name="$1"
  local profile_auth="${auth_profiles_dir}/${name}.json"
  local tmp_home result line maybe

  if [ ! -f "$profile_auth" ]; then
    echo "cx-switch: no auth stored yet for profile $name" >&2
    exit 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "cx-switch: jq is required for limits" >&2
    exit 1
  fi
  if ! command -v codex >/dev/null 2>&1; then
    echo "cx-switch: codex is required for limits" >&2
    exit 1
  fi

  tmp_home="$(mktemp -d "${auth_profiles_dir}/.cx-switch-home.XXXXXX")"
  mkdir -p "${tmp_home}/.codex"
  ln -s "$profile_auth" "${tmp_home}/.codex/auth.json"

  cleanup_limits() {
    if [ -n "${APP_PID:-}" ]; then
      kill "$APP_PID" 2>/dev/null || true
      wait "$APP_PID" 2>/dev/null || true
    fi
    rm -rf "$tmp_home"
  }

  trap cleanup_limits RETURN

  result=""
  coproc APP { HOME="$tmp_home" codex app-server 2>/dev/null; }

  printf '%s\n' '{"method":"initialize","id":1,"params":{"clientInfo":{"name":"cx-switch","title":"cx-switch","version":"1"},"capabilities":{"experimentalApi":true}}}' >&"${APP[1]}"
  while IFS= read -r -t 5 line <&"${APP[0]}"; do
    if printf '%s\n' "$line" | jq -e '.id == 1' >/dev/null 2>&1; then
      break
    fi
  done

  printf '%s\n' '{"method":"initialized"}' >&"${APP[1]}"
  printf '%s\n' '{"method":"account/rateLimits/read","id":2,"params":null}' >&"${APP[1]}"
  while IFS= read -r -t 10 line <&"${APP[0]}"; do
    maybe="$(printf '%s\n' "$line" | jq -c 'select(.id == 2) | .result' 2>/dev/null || true)"
    if [ -n "$maybe" ]; then
      result="$maybe"
      break
    fi
  done

  if [ -z "$result" ]; then
    echo "cx-switch: failed to read limits for profile $name" >&2
    exit 1
  fi

  printf '%s\n' "$result"
}

print_limits() {
  local name="$1"
  local payload snapshot plan credits_has credits_unlimited credits_balance
  local primary_used primary_mins primary_reset secondary_used secondary_mins secondary_reset
  local left label

  payload="$(fetch_limits_json "$name")"
  snapshot="$(printf '%s\n' "$payload" | jq -c '.rateLimitsByLimitId.codex // .rateLimits')"

  plan="$(printf '%s\n' "$snapshot" | jq -r '.planType // "unknown"')"
  credits_has="$(printf '%s\n' "$snapshot" | jq -r '.credits.hasCredits // false')"
  credits_unlimited="$(printf '%s\n' "$snapshot" | jq -r '.credits.unlimited // false')"
  credits_balance="$(printf '%s\n' "$snapshot" | jq -r '.credits.balance // empty')"

  echo "profile: $name"
  echo "plan: $plan"

  primary_used="$(printf '%s\n' "$snapshot" | jq -r '.primary.usedPercent // empty')"
  primary_mins="$(printf '%s\n' "$snapshot" | jq -r '.primary.windowDurationMins // empty')"
  primary_reset="$(printf '%s\n' "$snapshot" | jq -r '.primary.resetsAt // empty')"
  if [ -n "$primary_used" ]; then
    left=$((100 - primary_used))
    label="$(window_label "$primary_mins" "Primary limit")"
    echo "$label: ${left}% left (resets $(format_reset_at "$primary_reset"))"
  fi

  secondary_used="$(printf '%s\n' "$snapshot" | jq -r '.secondary.usedPercent // empty')"
  secondary_mins="$(printf '%s\n' "$snapshot" | jq -r '.secondary.windowDurationMins // empty')"
  secondary_reset="$(printf '%s\n' "$snapshot" | jq -r '.secondary.resetsAt // empty')"
  if [ -n "$secondary_used" ]; then
    left=$((100 - secondary_used))
    label="$(window_label "$secondary_mins" "Secondary limit")"
    echo "$label: ${left}% left (resets $(format_reset_at "$secondary_reset"))"
  fi

  if [ "$credits_unlimited" = "true" ]; then
    echo "credits: unlimited"
  elif [ "$credits_has" = "true" ] && [ -n "$credits_balance" ]; then
    echo "credits: $credits_balance"
  else
    echo "credits: none"
  fi
}

cmd="${1:-status}"

case "$cmd" in
  use)
    name="${2:-}"
    if [ -z "$name" ]; then
      usage >&2
      exit 1
    fi
    validate_profile_name "$name"
    mkdir -p "$auth_profiles_dir" "$shared_home"
    profile_auth="${auth_profiles_dir}/${name}.json"
    printf '%s\n' "$name" > "$current_file"
    if [ ! -e "$profile_auth" ]; then
      echo "cx-switch: no auth stored yet for profile $name" >&2
      echo "run: cx login" >&2
      printf '{}' > "$profile_auth"
    fi
    ln -sfn "$profile_auth" "$shared_auth"
    echo "active profile: $name"
    echo "auth: $profile_auth"
    ;;
  current)
    get_current_profile
    ;;
  list)
    mkdir -p "$auth_profiles_dir"
    current=""
    if [ -f "$current_file" ]; then
      current="$(tr -d '[:space:]' < "$current_file")"
    fi
    found=0
    for path in "$auth_profiles_dir"/*.json; do
      if [ ! -f "$path" ]; then
        continue
      fi
      found=1
      name="$(basename "$path" .json)"
      if [ "$name" = "$current" ]; then
        echo "* $name"
      else
        echo "  $name"
      fi
    done
    if [ "$found" -eq 0 ]; then
      echo "no profiles"
    fi
    ;;
  status)
    if [ -f "$current_file" ]; then
      name="$(tr -d '[:space:]' < "$current_file")"
      echo "mode: auth-profile"
      echo "profile: ${name:-unset}"
      echo "auth: ${auth_profiles_dir}/${name}.json"
      echo "state: ${shared_home}"
    else
      echo "mode: unset"
      echo "profile: unset"
      echo "auth: unset"
      echo "state: ${shared_home}"
    fi
    ;;
  limits)
    name="${2:-}"
    if [ -z "$name" ]; then
      name="$(get_current_profile)"
      if [ "$name" = "unset" ]; then
        echo "cx-switch: no active profile" >&2
        exit 1
      fi
    fi
    validate_profile_name "$name"
    print_limits "$name"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
